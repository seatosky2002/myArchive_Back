# ── Django ───────────────────────────────────────
DEBUG=False
SECRET_KEY=여기에-강력한-시크릿키-입력
ALLOWED_HOSTS=your-ec2-ip,your-domain.com

# ── PostgreSQL ────────────────────────────────────
# 로컬: docker-compose db 서비스 사용
# 프로덕션: RDS 엔드포인트로 변경
DB_NAME=mymemorymap
DB_USER=dbuser
DB_PASSWORD=강력한-DB-비밀번호
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2
REDIS_BLACKLIST_URL=redis://redis:6379/3

# ── Gemini API ────────────────────────────────────
GEMINI_API_KEY=여기에-Gemini-API-키-입력
